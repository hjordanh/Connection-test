# Connection Monitor — local configuration template.
# Copy this file to `connection_monitor.env` and fill in your values.
# That file is gitignored; this one is committed as a template.
#
# Values set in your shell environment take precedence over this file.

# ── Anthropic API ──────────────────────────────────────────────
# Required to use the AI Diagnosis feature.
ANTHROPIC_API_KEY=

# ── Router log scraping ────────────────────────────────────────
# URL of the router whose log pages should be scraped.
# Leave blank to disable scraping entirely.
GATEWAY_URL=

# Path on the gateway for the firewall / packet log (HTML page).
# Example for AT&T-style residential gateways: /cgi-bin/logs.ha
ROUTER_PACKET_LOG_PATH=

# Path on the gateway for the system event log. Optional — leave blank to skip.
# Example for AT&T-style residential gateways: /cgi-bin/syslog.ha
ROUTER_SYSLOG_PATH=

# Seconds between gateway polls.
ROUTER_POLL_INTERVAL=30

# ── Dashboard ──────────────────────────────────────────────────
PORT=8765

# Interface the dashboard binds to. Default 127.0.0.1 = loopback only (safe:
# reachable only from this machine, and — on a VPS — only via local nginx).
# Set to 0.0.0.0 to reach the dashboard from other devices on your network;
# if you do, also set DASHBOARD_USER/DASHBOARD_PASS below so it isn't open.
BIND_HOST=127.0.0.1

# ── Storage ────────────────────────────────────────────────────
# Path to the SQLite store. Leave blank to use ./connection_monitor.db
# next to this script.
DATA_DB=

# Per-table retention windows. Defaults preserve the behavior the JSON store
# had: 30 days for ping/site/outage/event/diagnosis history, 24 hours for
# individual speed-test samples, 7 days for the daily uptime chart.
RETAIN_PINGS_DAYS=30
RETAIN_SITE_PINGS_DAYS=30
RETAIN_OUTAGES_DAYS=30
RETAIN_DEGRADED_DAYS=30
RETAIN_ROUTER_DAYS=30
RETAIN_DIAGNOSES_DAYS=30
RETAIN_SPEED_HOURS=24
RETAIN_DAILY_DAYS=7

# Minimum gap (in minutes) before "monitor not running" downtime is rendered
# as a dim segment on the uptime timeline. Lower values surface short
# laptop-sleep / Power-Nap windows; higher values only flag genuine restarts
# and long away-from-keyboard windows. Set to 0 to render every gap.
MONITOR_GAP_MIN_REPORT_MIN=60

# ── High-ping detection ───────────────────────────────────────
# Absolute floor (ms). Below this, latency is never "high" regardless of
# the network's percentile baseline.
HIGH_PING_FLOOR_MS=75

# Percentile of your own probes (last 7d, excluding prior high-ping windows)
# used as the trigger. P99 = "your normal worst." Use 97 to be more
# sensitive, 99.5 to be stricter.
HIGH_PING_BASELINE_PCT=99

# ── Site-tile verdicts (GREAT / OK / SLOW / POOR) ────────────
# Each site is graded relative to the union of all sites' successful pings
# over a recent window. Verdict = worst of (latency band, reachability band).
SITE_VERDICT_BASELINE_HOURS=24
SITE_VERDICT_FALLBACK_HOURS=168
SITE_VERDICT_MIN_SAMPLES=200
SITE_VERDICT_GREAT_PCT=10
SITE_VERDICT_SLOW_PCT=90
SITE_VERDICT_POOR_PCT=99
SITE_VERDICT_GREAT_REACH=99
SITE_VERDICT_OK_REACH=95
SITE_VERDICT_SLOW_REACH=80

# ── Multi-host / VPS sync ─────────────────────────────────────
# Set SERVER_URL on collector machines to enable syncing data to a central VPS.
# The VPS receives data via the /api/ingest endpoint.
SERVER_URL=

# Shared secret for the ingest API. Set on both the VPS and collectors.
INGEST_API_KEY=

# HTTP Basic Auth for the dashboard (recommended on the VPS).
DASHBOARD_USER=
DASHBOARD_PASS=

# Identity of this monitoring host. Defaults to the system hostname.
MONITOR_HOST=

# Set to true on the VPS to skip speed tests and save bandwidth.
DISABLE_SPEED_TESTS=false

# Set to true on the VPS to always show aggregated multi-host view.
AGGREGATOR=false
