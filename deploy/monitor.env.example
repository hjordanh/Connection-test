# Runtime secrets/config for the cloud server. Copy to `monitor.env` on the
# instance (chmod 600) and fill in. NEVER commit the real file.

# Signs session cookies. Generate once and keep stable:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Invite code friends must enter to register. Blank = registration closed.
SIGNUP_CODE=

# Optional tuning (defaults shown):
# INGEST_MAX_MB=25
# INGEST_MIN_INTERVAL_S=20
# RETAIN_PINGS_DAYS=30
